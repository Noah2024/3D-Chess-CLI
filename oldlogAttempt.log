// Custom logger config
package log

import (
	"log/slog"
	"os"
)

// os.UserConfigDir()//May need this in the future
var logger *slog.Logger
var toJson bool
var handleOptions *slog.HandlerOptions

func init() {
	handleOptions := &slog.HandlerOptions{
		Level:     slog.LevelDebug,
		AddSource: true,
	}

	handler := slog.NewTextHandler(os.Stdout, handleOptions)
	logger = slog.New(handler)
}

func Debug(msg string) {
	logger.Debug(msg)
}

func Info(msg string) {
	logger.Info(msg)
}

func Warn(msg string) {
	logger.Warn(msg)
}

func Error(msg string) {
	logger.Error(msg)
}

func Fatal(msg string) {
	logger.Error(msg)
	os.Exit(1)
	//Exit
}

func SetLogLevl(level slog.Level) {
	handleOptions = &slog.HandlerOptions{Level: level, AddSource: true}

	if toJson == true {
		logger = slog.New(slog.NewJSONHandler(os.Stdout, handleOptions))
	} else {
		logger = slog.New(slog.NewTextHandler(os.Stdout, handleOptions))
	}
}

func OutputToJson(level slog.Level) {
	newHandler := slog.NewJSONHandler(os.Stdout, handleOptions)
	logger = slog.New(newHandler)
}

func OutputToStdout(level slog.Level) {
	newHandler := slog.NewTextHandler(os.Stdout, handleOptions)
	logger = slog.New(newHandler)
}
